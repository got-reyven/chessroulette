{
  "name": "chess-roulette",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "npm run dev --prefix client",
    "build": "npm install --prefix client --include=dev && npm run build --prefix client && npm run build:server",
    "build:client": "npm install --prefix client --include=dev && npm run build --prefix client",
    "build:server": "tsc -p server/tsconfig.json",
    "start": "node server/dist/index.js"
  },
  "dependencies": {
    "chess.js": "^1.0.0-beta.8",
    "express": "^4.21.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
